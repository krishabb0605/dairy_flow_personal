generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  CUSTOMER
}

model User {
  id          Int    @id @default(autoincrement())
  firebaseUid String @unique

  fullName     String
  mobileNumber String @unique
  email        String @unique
  address      String

  role           UserRole?
  onboarded      Boolean   @default(false)
  onboardingStep Int       @default(1)

  profileImageUrl String?

  ownerSettings    OwnerSettings?
  customerSettings CustomerSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// OWNER SETTINGS = BUSINESS + DELIVERY + PAYMENT
//
model OwnerSettings {
  id     Int @id @default(autoincrement())
  userId Int @unique

  dairyName String

  cowEnabled Boolean @default(true)
  cowPrice   Decimal @db.Decimal(10, 2)

  buffaloEnabled Boolean @default(true)
  buffaloPrice   Decimal @db.Decimal(10, 2)

  // DELIVERY TIMES (TIME ONLY)
  morningStart DateTime @default(dbgenerated("'06:00:00'")) @db.Time
  morningEnd   DateTime @default(dbgenerated("'09:00:00'")) @db.Time

  eveningStart DateTime @default(dbgenerated("'18:00:00'")) @db.Time
  eveningEnd   DateTime @default(dbgenerated("'21:00:00'")) @db.Time

  // PAYMENT INFO
  upiId         String?
  bankName      String?
  accountNumber String?
  ifscCode      String?

  user User @relation(fields: [userId], references: [id])

  customerOwners CustomerOwner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// CUSTOMER SETTINGS (ONLY MILK QTY)
// ONE PER CUSTOMER
//
model CustomerSettings {
  id Int @id @default(autoincrement())

  userId Int @unique

  morningCowQty     Decimal @default(0) @db.Decimal(10, 2)
  morningBuffaloQty Decimal @default(0) @db.Decimal(10, 2)

  eveningCowQty     Decimal @default(0) @db.Decimal(10, 2)
  eveningBuffaloQty Decimal @default(0) @db.Decimal(10, 2)

  user           User            @relation(fields: [userId], references: [id])
  customerOwners CustomerOwner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//
// CUSTOMER ↔ OWNER RELATION + ACTIVATION + HISTORY
//
model CustomerOwner {
  id Int @id @default(autoincrement())

  customerId Int
  ownerId    Int

  isActivated Boolean @default(true)

  customer          CustomerSettings   @relation(fields: [customerId], references: [id])
  owner             OwnerSettings      @relation(fields: [ownerId], references: [id])
  extraMilkOrders   ExtraMilkOrder[]
  vacationSchedules VacationSchedule[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  dailyMilks DailyMilk[]

  @@index([customerId])
  @@index([ownerId])
}

enum ExtraMilkSlot {
  MORNING
  EVENING
}

model ExtraMilkOrder {
  id Int @id @default(autoincrement())

  customerOwnerId Int
  customerOwner   CustomerOwner @relation(fields: [customerOwnerId], references: [id])

  deliveryDate DateTime      @db.Date
  slot         ExtraMilkSlot
  cowQty       Decimal       @default(0) @db.Decimal(10, 2)
  buffaloQty   Decimal       @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerOwnerId, deliveryDate, slot])
  @@index([customerOwnerId])
  @@index([deliveryDate])
}

model VacationSchedule {
  id Int @id @default(autoincrement())

  customerOwnerId Int
  customerOwner   CustomerOwner @relation(fields: [customerOwnerId], references: [id])

  startDate DateTime      @db.Date
  startSlot ExtraMilkSlot

  endDate DateTime      @db.Date
  endSlot ExtraMilkSlot

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerOwnerId])
  @@index([startDate])
}

enum DailyMilkSource {
  CRON
  MANUAL
}

model DailyMilk {
  id Int @id @default(autoincrement())

  customerOwnerId Int
  customerOwner   CustomerOwner @relation(fields: [customerOwnerId], references: [id])

  deliveryDate DateTime      @db.Date
  slot         ExtraMilkSlot

  cowQty     Decimal @default(0) @db.Decimal(10, 2)
  buffaloQty Decimal @default(0) @db.Decimal(10, 2)

  cowPrice     Decimal @db.Decimal(10, 2)
  buffaloPrice Decimal @db.Decimal(10, 2)

  totalAmount Decimal @db.Decimal(10, 2)

  source DailyMilkSource @default(CRON)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerOwnerId, deliveryDate, slot])
  @@index([customerOwnerId])
  @@index([deliveryDate])
}
